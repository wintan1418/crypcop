<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Watchlist</h1>
      <p class="text-sm text-gray-400 mt-1">Tokens you're tracking for risk changes.</p>
    </div>
  </div>

  <% if @watchlist_items.any? %>
    <div class="space-y-3">
      <% @watchlist_items.each do |item| %>
        <div id="<%= dom_id(item) %>" class="card flex items-center justify-between">
          <div class="flex items-center gap-3">
            <% if item.token.image_url.present? %>
              <img src="<%= item.token.image_url %>" class="w-10 h-10 rounded-full bg-gray-800" loading="lazy">
            <% else %>
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-green/20 to-brand-cyan/20 flex items-center justify-center text-sm font-bold text-brand-green">
                <%= item.token.symbol&.first(2)&.upcase || "?" %>
              </div>
            <% end %>
            <div>
              <%= link_to token_path(item.token.mint_address), class: "text-white font-semibold hover:text-brand-green" do %>
                <%= item.token.name || "Unknown" %>
              <% end %>
              <div class="text-xs text-gray-500"><%= item.token.symbol %></div>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <% if item.token.risk_score %>
              <%= render "shared/risk_badge", level: item.token.risk_level, score: item.token.risk_score %>
            <% end %>
            <%= button_to watchlist_item_path(item), method: :delete, class: "text-gray-500 hover:text-red-400 transition-colors text-sm" do %>
              Remove
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-16">
      <div class="text-4xl mb-4">&#128064;</div>
      <h3 class="text-lg font-semibold text-white mb-2">Your watchlist is empty</h3>
      <p class="text-gray-400 mb-4">Add tokens from the feed or search to track their risk levels.</p>
      <%= link_to "Browse Live Feed", feed_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
