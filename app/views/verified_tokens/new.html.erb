<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-white">Get Your Token Verified</h1>
    <p class="text-sm text-gray-400 mt-1">Submit your token for a CrypCop security audit and verified badge.</p>
  </div>

  <div class="card">
    <%= form_with model: @verified_token, url: verified_tokens_path, class: "space-y-5" do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Token Mint Address</label>
        <%= f.text_field :mint_address, placeholder: "Solana token address...", class: "input-field font-mono text-sm", name: "verified_token[mint_address]" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Project Name</label>
        <%= f.text_field :project_name, placeholder: "Your token/project name", class: "input-field" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Badge Type</label>
        <%= f.select :badge_type, [["Basic — $200", "basic"], ["Premium — $350", "premium"], ["Gold — $500", "gold"]], {}, class: "input-field" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Contact Email</label>
        <%= f.email_field :contact_email, placeholder: "you@project.com", class: "input-field" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Project Website</label>
        <%= f.url_field :project_url, placeholder: "https://yourproject.com", class: "input-field" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Description</label>
        <%= f.text_area :description, placeholder: "Tell us about your token and project...", class: "input-field h-24", maxlength: 500 %>
      </div>

      <div class="p-4 rounded-lg bg-brand-cyan/5 border border-brand-cyan/20">
        <p class="text-sm text-gray-300">After submission, we'll review your token within 24 hours. Payment instructions will be sent to your email. Badge is active for 1 year after payment.</p>
      </div>

      <%= f.submit "Submit for Verification", class: "btn-primary w-full cursor-pointer" %>
    <% end %>
  </div>
</div>
