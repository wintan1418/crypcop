<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">API Keys</h1>
      <p class="text-sm text-gray-400 mt-1">Use the CrypCop API to scan tokens programmatically.</p>
    </div>
  </div>

  <!-- API Docs Summary -->
  <div class="card mb-8">
    <h2 class="text-lg font-semibold text-white mb-4">Quick Start</h2>
    <div class="bg-gray-900 rounded-lg p-4 font-mono text-sm text-gray-300 overflow-x-auto">
      <div class="text-gray-500"># Scan a token</div>
      <div>curl -H "X-Api-Key: YOUR_KEY" <%= request.base_url %>/api/v1/scan/TOKEN_ADDRESS</div>
      <div class="mt-3 text-gray-500"># Get token info</div>
      <div>curl -H "X-Api-Key: YOUR_KEY" <%= request.base_url %>/api/v1/token/TOKEN_ADDRESS</div>
    </div>
    <div class="mt-4 grid grid-cols-3 gap-4 text-center">
      <div class="p-3 rounded-lg bg-gray-900">
        <div class="text-sm font-semibold text-white">Free</div>
        <div class="text-xs text-gray-400">100 calls/day</div>
        <div class="text-lg font-bold text-brand-green mt-1">$0</div>
      </div>
      <div class="p-3 rounded-lg bg-gray-900 border border-brand-green/30">
        <div class="text-sm font-semibold text-brand-green">Pro</div>
        <div class="text-xs text-gray-400">10,000 calls/day</div>
        <div class="text-lg font-bold text-white mt-1">$49/mo</div>
      </div>
      <div class="p-3 rounded-lg bg-gray-900">
        <div class="text-sm font-semibold text-brand-cyan">Enterprise</div>
        <div class="text-xs text-gray-400">100,000 calls/day</div>
        <div class="text-lg font-bold text-white mt-1">Contact us</div>
      </div>
    </div>
  </div>

  <!-- Create Key -->
  <div class="card mb-8">
    <%= form_with url: api_keys_path, method: :post, class: "flex items-end gap-4" do |f| %>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-300 mb-1">Key Name</label>
        <%= f.text_field :name, value: "My API Key", class: "input-field", name: "api_key[name]" %>
      </div>
      <%= f.submit "Generate API Key", class: "btn-primary cursor-pointer whitespace-nowrap" %>
    <% end %>
  </div>

  <!-- Existing Keys -->
  <% if @api_keys.any? %>
    <div class="space-y-3">
      <% @api_keys.each do |key| %>
        <div class="card flex items-center justify-between">
          <div>
            <div class="flex items-center gap-3">
              <span class="text-white font-medium"><%= key.name || "API Key" %></span>
              <% if key.active? %>
                <span class="text-xs bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full">Active</span>
              <% else %>
                <span class="text-xs bg-red-500/20 text-red-400 px-2 py-0.5 rounded-full">Inactive</span>
              <% end %>
              <span class="text-xs bg-brand-cyan/20 text-brand-cyan px-2 py-0.5 rounded-full"><%= key.tier.titleize %></span>
            </div>
            <div class="text-sm text-gray-400 font-mono mt-1"><%= key.key %></div>
            <div class="text-xs text-gray-500 mt-1">
              <%= key.calls_today %>/<%= key.calls_limit %> calls today
              <% if key.last_used_at %> · Last used <%= time_ago_in_words(key.last_used_at) %> ago<% end %>
            </div>
          </div>
          <% if key.active? %>
            <%= button_to "Revoke", api_key_path(key), method: :delete, class: "text-sm text-red-400 hover:text-red-300", data: { turbo_confirm: "Revoke this API key?" } %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <div class="text-4xl mb-4">&#128273;</div>
      <h3 class="text-lg font-semibold text-white mb-2">No API keys yet</h3>
      <p class="text-gray-400">Generate a key above to start using the CrypCop API.</p>
    </div>
  <% end %>
</div>
