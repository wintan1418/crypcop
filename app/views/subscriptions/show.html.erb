<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="text-center mb-12">
    <h1 class="text-3xl font-bold text-white">Upgrade to Pro</h1>
    <p class="mt-2 text-gray-400">Unlock unlimited scans, AI deep analysis, and real-time alerts.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Free -->
    <div class="card">
      <h3 class="text-lg font-semibold text-gray-300">Free</h3>
      <div class="mt-4 flex items-baseline gap-1">
        <span class="text-4xl font-bold text-white">$0</span>
        <span class="text-gray-500">/month</span>
      </div>
      <ul class="mt-8 space-y-3">
        <li class="flex items-center gap-3 text-sm text-gray-400">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          10 scans per day
        </li>
        <li class="flex items-center gap-3 text-sm text-gray-400">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Live token feed
        </li>
        <li class="flex items-center gap-3 text-sm text-gray-400">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Basic risk scores
        </li>
      </ul>
      <div class="mt-8">
        <% if user_signed_in? && current_user.free? %>
          <span class="btn-secondary w-full text-center opacity-50">Current Plan</span>
        <% else %>
          <%= link_to "Get Started", new_user_registration_path, class: "btn-secondary w-full text-center" %>
        <% end %>
      </div>
    </div>

    <!-- Pro -->
    <div class="card border-brand-green/30 relative glow-green">
      <div class="absolute -top-3 left-1/2 -translate-x-1/2">
        <span class="px-3 py-1 bg-brand-green text-black text-xs font-bold rounded-full">RECOMMENDED</span>
      </div>
      <h3 class="text-lg font-semibold text-brand-green">Pro</h3>
      <div class="mt-4 flex items-baseline gap-1">
        <span class="text-4xl font-bold text-white">$19</span>
        <span class="text-gray-500">/month</span>
      </div>
      <ul class="mt-8 space-y-3">
        <li class="flex items-center gap-3 text-sm text-gray-300">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          <strong>Unlimited</strong> scans
        </li>
        <li class="flex items-center gap-3 text-sm text-gray-300">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          AI deep analysis with explanations
        </li>
        <li class="flex items-center gap-3 text-sm text-gray-300">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Real-time alerts (email + push)
        </li>
        <li class="flex items-center gap-3 text-sm text-gray-300">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Unlimited watchlist
        </li>
        <li class="flex items-center gap-3 text-sm text-gray-300">
          <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          Priority scanning queue
        </li>
      </ul>
      <div class="mt-8">
        <% if user_signed_in? && current_user.pro? %>
          <span class="btn-primary w-full text-center opacity-50">Current Plan</span>
        <% else %>
          <%= button_to "Start Pro", subscription_path, method: :post, class: "btn-primary w-full", data: { turbo: false } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
