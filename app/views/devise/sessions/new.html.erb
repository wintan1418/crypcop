<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white">Welcome Back</h1>
      <p class="mt-2 text-gray-400">Sign in to your CrypCop account.</p>
    </div>

    <div class="card">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "input-field" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "Your password", class: "input-field" %>
        </div>

        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :remember_me, class: "w-4 h-4 rounded bg-gray-900 border-brand-border text-brand-green focus:ring-brand-green/50" %>
            <span class="text-sm text-gray-400">Remember me</span>
          </label>
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm text-brand-cyan hover:text-brand-cyan/80" %>
        </div>

        <div>
          <%= f.submit "Sign In", class: "btn-primary w-full cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <p class="text-sm text-gray-500">
          Don't have an account?
          <%= link_to "Sign up free", new_registration_path(resource_name), class: "text-brand-cyan hover:text-brand-cyan/80" %>
        </p>
      </div>
    </div>
  </div>
</div>
