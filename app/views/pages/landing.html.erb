<!-- Hero Section -->
<section class="relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-green/5 via-transparent to-transparent"></div>
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full bg-brand-green/5 blur-[120px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-green/10 border border-brand-green/20 mb-8">
        <span class="w-2 h-2 rounded-full bg-brand-green animate-pulse"></span>
        <span class="text-sm text-brand-green font-medium">Live scanning Solana tokens</span>
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight">
        <span class="text-white">Stop Getting</span>
        <br>
        <span class="bg-gradient-to-r from-brand-green to-brand-cyan bg-clip-text text-transparent">Rugged.</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        CrypCop scans new Solana tokens in real-time and uses AI to detect rug pulls, honeypots, and scam patterns
        <span class="text-white font-medium">before you invest.</span>
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <%= link_to new_user_registration_path, class: "btn-primary text-lg px-8 py-4 glow-green" do %>
          Start Scanning Free
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        <% end %>
        <%= link_to feed_path, class: "btn-secondary text-lg px-8 py-4" do %>
          View Live Feed
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        <% end %>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto">
        <div>
          <div class="text-2xl font-bold text-white"><%= Token.count %>+</div>
          <div class="text-sm text-gray-500">Tokens Scanned</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-red-400"><%= Token.where(risk_level: [:high, :critical]).count %></div>
          <div class="text-sm text-gray-500">Rugs Detected</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-green"><%= User.count %></div>
          <div class="text-sm text-gray-500">Traders Protected</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section class="py-24 border-t border-brand-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">How CrypCop Protects You</h2>
      <p class="mt-4 text-gray-400 max-w-2xl mx-auto">Three layers of defense between you and the next rug pull.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Step 1 -->
      <div class="card text-center group hover:border-brand-green/30 transition-all duration-300">
        <div class="w-16 h-16 rounded-2xl bg-brand-green/10 flex items-center justify-center mx-auto mb-6 group-hover:bg-brand-green/20 transition-colors">
          <svg class="w-8 h-8 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <div class="text-sm font-semibold text-brand-green mb-2">Step 1</div>
        <h3 class="text-xl font-bold text-white mb-3">Discover</h3>
        <p class="text-gray-400">New tokens appear in our live feed the moment they launch on Solana. No delays, no manual searching.</p>
      </div>

      <!-- Step 2 -->
      <div class="card text-center group hover:border-brand-cyan/30 transition-all duration-300">
        <div class="w-16 h-16 rounded-2xl bg-brand-cyan/10 flex items-center justify-center mx-auto mb-6 group-hover:bg-brand-cyan/20 transition-colors">
          <svg class="w-8 h-8 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
          </svg>
        </div>
        <div class="text-sm font-semibold text-brand-cyan mb-2">Step 2</div>
        <h3 class="text-xl font-bold text-white mb-3">Analyze</h3>
        <p class="text-gray-400">Our AI inspects holder distribution, liquidity locks, mint authority, and contract patterns. Risk score 0-100.</p>
      </div>

      <!-- Step 3 -->
      <div class="card text-center group hover:border-purple-500/30 transition-all duration-300">
        <div class="w-16 h-16 rounded-2xl bg-purple-500/10 flex items-center justify-center mx-auto mb-6 group-hover:bg-purple-500/20 transition-colors">
          <svg class="w-8 h-8 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <div class="text-sm font-semibold text-purple-400 mb-2">Step 3</div>
        <h3 class="text-xl font-bold text-white mb-3">Protect</h3>
        <p class="text-gray-400">Get real-time alerts when risk changes. Add tokens to your watchlist. Invest with confidence or walk away.</p>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-24 border-t border-brand-border bg-gradient-to-b from-transparent via-brand-cyan/5 to-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
