<footer class="border-t border-brand-border mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-brand-green/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <span class="text-lg font-bold text-white">Cryp<span class="text-brand-green">Cop</span></span>
        </div>
        <p class="text-gray-500 text-sm max-w-md">Real-time Solana token scanner powered by AI. Protecting crypto traders from rug pulls and scam tokens.</p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm font-semibold text-gray-300 mb-4">Product</h4>
        <ul class="space-y-2">
          <li><%= link_to "Live Feed", feed_path, class: "text-sm text-gray-500 hover:text-brand-green transition-colors" %></li>
          <li><%= link_to "Search", search_path, class: "text-sm text-gray-500 hover:text-brand-green transition-colors" %></li>
          <li><%= link_to "Pricing", subscription_path, class: "text-sm text-gray-500 hover:text-brand-green transition-colors" %></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-gray-300 mb-4">Legal</h4>
        <ul class="space-y-2">
          <li><span class="text-sm text-gray-500">Terms of Service</span></li>
          <li><span class="text-sm text-gray-500">Privacy Policy</span></li>
          <li><span class="text-sm text-gray-500">Disclaimer</span></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-brand-border flex items-center justify-between">
      <p class="text-xs text-gray-600">&copy; <%= Date.current.year %> CrypCop. Not financial advice. DYOR.</p>
      <p class="text-xs text-gray-600">Built with Rails 8</p>
    </div>
  </div>
</footer>
