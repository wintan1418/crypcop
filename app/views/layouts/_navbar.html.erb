<nav class="sticky top-0 z-50 bg-brand-dark/95 backdrop-blur-sm border-b border-brand-border" data-controller="mobile-menu">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center gap-8">
        <%= link_to root_path, class: "flex items-center gap-2 group" do %>
          <div class="w-8 h-8 rounded-lg bg-brand-green/20 flex items-center justify-center group-hover:bg-brand-green/30 transition-colors">
            <svg class="w-5 h-5 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <span class="text-xl font-bold text-white">Cryp<span class="text-brand-green">Cop</span></span>
        <% end %>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-5">
          <%= link_to "Feed", feed_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(feed_path)}" %>
          <%= link_to "Smart Money", smart_money_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(smart_money_path)}" %>
          <%= link_to "Search", search_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(search_path)}" %>
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(dashboard_path)}" %>
            <%= link_to "Wallets", tracked_wallets_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(tracked_wallets_path)}" %>
            <%= link_to "Portfolio", portfolio_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(portfolio_path)}" %>
            <%= link_to "Watchlist", watchlist_items_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(watchlist_items_path)}" %>
            <%= link_to "API", api_keys_path, class: "text-sm text-gray-400 hover:text-brand-green transition-colors #{'!text-brand-green font-medium' if current_page?(api_keys_path)}" %>
          <% end %>
        </div>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <% if user_signed_in? %>
          <%= link_to alerts_path, class: "relative text-gray-400 hover:text-brand-cyan transition-colors" do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
            <% unread_count = current_user.alerts.unread.count %>
            <% if unread_count > 0 %>
              <span class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full text-[10px] font-bold flex items-center justify-center text-white"><%= unread_count > 9 ? "9+" : unread_count %></span>
            <% end %>
          <% end %>

          <div class="hidden sm:flex items-center gap-3">
            <% unless current_user.pro? %>
              <%= link_to "Upgrade", subscription_path, class: "btn-sm btn-primary text-xs" %>
            <% else %>
              <span class="text-xs bg-brand-green/20 text-brand-green px-2 py-0.5 rounded-full font-semibold">PRO</span>
            <% end %>
            <div class="text-sm text-gray-400 hidden lg:block"><%= current_user.email.split("@").first %></div>
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-300 transition-colors hidden sm:block" %>
          </div>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "text-sm text-gray-400 hover:text-white transition-colors hidden sm:block" %>
          <%= link_to "Get Started", new_user_registration_path, class: "btn-sm btn-primary" %>
        <% end %>

        <!-- Mobile hamburger -->
        <button class="md:hidden text-gray-400 hover:text-white" data-action="click->mobile-menu#toggle">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-mobile-menu-target="icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="hidden md:hidden border-t border-brand-border bg-brand-dark" data-mobile-menu-target="menu">
    <div class="px-4 py-4 space-y-2">
      <%= link_to "Live Feed", feed_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
      <%= link_to "Smart Money", smart_money_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
      <%= link_to "Search", search_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
      <% if user_signed_in? %>
        <div class="border-t border-brand-border my-2"></div>
        <%= link_to "Dashboard", dashboard_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
        <%= link_to "Wallet Tracker", tracked_wallets_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
        <%= link_to "Portfolio", portfolio_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
        <%= link_to "Watchlist", watchlist_items_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
        <%= link_to "Alerts", alerts_path, class: "block py-2 text-sm text-gray-300 hover:text-brand-green" %>
        <div class="border-t border-brand-border my-2"></div>
        <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block py-2 text-sm text-red-400" %>
      <% else %>
        <div class="border-t border-brand-border my-2"></div>
        <%= link_to "Sign In", new_user_session_path, class: "block py-2 text-sm text-gray-300" %>
        <%= link_to "Sign Up Free", new_user_registration_path, class: "block py-2 text-sm text-brand-green font-medium" %>
      <% end %>
    </div>
  </div>
</nav>
