<div id="flash-messages" class="fixed top-20 right-4 z-50 flex flex-col gap-2" data-controller="toast">
  <% flash.each do |type, message| %>
    <% color = case type.to_s
       when "notice", "success" then "border-brand-green/50 bg-brand-green/10 text-brand-green"
       when "alert", "error" then "border-red-500/50 bg-red-500/10 text-red-400"
       else "border-brand-cyan/50 bg-brand-cyan/10 text-brand-cyan"
       end %>
    <div class="flex items-center gap-3 px-4 py-3 rounded-lg border <%= color %> shadow-lg animate-slide-in" data-toast-target="message">
      <span class="text-sm font-medium"><%= message %></span>
      <button class="ml-auto text-current opacity-50 hover:opacity-100" data-action="click->toast#dismiss">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  <% end %>
</div>
