<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Wallet Tracker</h1>
      <p class="text-sm text-gray-400 mt-1">Track whale wallets and get alerts on their trades.</p>
    </div>
  </div>

  <!-- Add Wallet Form -->
  <div class="card mb-8">
    <h2 class="text-lg font-semibold text-white mb-4">Track a Wallet</h2>
    <%= form_with model: TrackedWallet.new, url: tracked_wallets_path, class: "space-y-4" do |f| %>
      <div class="flex gap-3">
        <%= f.text_field :wallet_address, placeholder: "Paste Solana wallet address...", class: "input-field flex-1 font-mono text-sm" %>
        <%= f.text_field :label, placeholder: "Label (optional)", class: "input-field w-48" %>
        <%= f.submit "Track Wallet", class: "btn-primary cursor-pointer whitespace-nowrap" %>
      </div>
      <div class="flex items-center gap-6">
        <label class="flex items-center gap-2 text-sm text-gray-400 cursor-pointer">
          <%= f.check_box :notify_on_buy, checked: true, class: "rounded bg-gray-900 border-brand-border text-brand-green" %>
          Alert on buys
        </label>
        <label class="flex items-center gap-2 text-sm text-gray-400 cursor-pointer">
          <%= f.check_box :notify_on_sell, checked: true, class: "rounded bg-gray-900 border-brand-border text-brand-green" %>
          Alert on sells
        </label>
      </div>
    <% end %>
  </div>

  <!-- Tracked Wallets -->
  <% if @tracked_wallets.any? %>
    <div class="space-y-3">
      <% @tracked_wallets.each do |wallet| %>
        <div class="card flex items-center justify-between">
          <div class="flex items-center gap-4 min-w-0">
            <div class="w-10 h-10 rounded-full bg-brand-cyan/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3" />
              </svg>
            </div>
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <%= link_to tracked_wallet_path(wallet), class: "text-white font-semibold hover:text-brand-cyan truncate" do %>
                  <%= wallet.label.present? ? wallet.label : wallet.wallet_address.truncate(20) %>
                <% end %>
                <% if wallet.is_whale? %>
                  <span class="text-xs bg-brand-cyan/20 text-brand-cyan px-2 py-0.5 rounded-full">Whale</span>
                <% end %>
                <% if wallet.is_smart_money? %>
                  <span class="text-xs bg-brand-green/20 text-brand-green px-2 py-0.5 rounded-full">Smart Money</span>
                <% end %>
              </div>
              <div class="text-xs text-gray-500 font-mono truncate"><%= wallet.wallet_address %></div>
            </div>
          </div>

          <div class="flex items-center gap-3 shrink-0">
            <% if wallet.last_activity_at %>
              <span class="text-xs text-gray-500"><%= time_ago_in_words(wallet.last_activity_at) %> ago</span>
            <% end %>
            <span class="text-xs text-gray-500"><%= wallet.wallet_transactions.count %> txns</span>
            <%= button_to tracked_wallet_path(wallet), method: :delete, class: "text-gray-500 hover:text-red-400 text-sm transition-colors" do %>
              Remove
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-16">
      <div class="text-4xl mb-4">&#128051;</div>
      <h3 class="text-lg font-semibold text-white mb-2">No wallets tracked yet</h3>
      <p class="text-gray-400">Add a whale wallet address above to start tracking their trades.</p>
    </div>
  <% end %>
</div>
