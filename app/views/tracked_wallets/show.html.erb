<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @wallet.label || "Wallet" %></h1>
      <p class="text-sm text-gray-500 font-mono mt-1"><%= @wallet.wallet_address %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= button_to "Refresh", refresh_tracked_wallet_path(@wallet), method: :post, class: "btn-sm btn-secondary" %>
      <%= link_to "Back", tracked_wallets_path, class: "btn-sm text-gray-400 hover:text-white border border-brand-border rounded-md px-3 py-1.5" %>
    </div>
  </div>

  <!-- Transaction Feed -->
  <div class="card">
    <h2 class="text-lg font-semibold text-white mb-4">Recent Transactions</h2>
    <% if @transactions.any? %>
      <div class="space-y-3">
        <% @transactions.each do |tx| %>
          <div class="flex items-center justify-between py-3 border-b border-brand-border last:border-0">
            <div class="flex items-center gap-3">
              <% if tx.buy? %>
                <span class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center text-green-400 text-sm font-bold">B</span>
              <% else %>
                <span class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 text-sm font-bold">S</span>
              <% end %>
              <div>
                <div class="text-sm text-white font-medium">
                  <%= tx.tx_type.titleize %> <%= tx.token_symbol || "Unknown" %>
                </div>
                <div class="text-xs text-gray-500">
                  <% if tx.transacted_at %>
                    <%= time_ago_in_words(tx.transacted_at) %> ago
                  <% end %>
                </div>
              </div>
            </div>
            <div class="text-right">
              <% if tx.value_usd %>
                <div class="text-sm text-white font-mono">$<%= number_with_delimiter(tx.value_usd.round(2)) %></div>
              <% end %>
              <% if tx.amount %>
                <div class="text-xs text-gray-500"><%= number_with_delimiter(tx.amount.round(4)) %> tokens</div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-400">No transactions found yet. Click "Refresh" to fetch latest activity.</p>
      </div>
    <% end %>
  </div>
</div>
